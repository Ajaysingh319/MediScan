# --- MediScan backend environment ---
# Copy this file to ".env" and fill in your values.

# Google Gemini API key (required). Get one at https://aistudio.google.com/apikey
AI_API_KEY=your_gemini_api_key_here

# Gemini model to use. Flash is fast & cheap; Pro is more thorough but slower.
AI_MODEL=gemini-2.5-flash

# Port the server listens on.
PORT=3000

# development | production
NODE_ENV=development

# Comma-separated allowed frontend origins. Use "*" for local dev only.
# Example for prod: https://mediscan.example.com,https://www.mediscan.example.com
CORS_ORIGINS=*
